# Runtime database. SQLite is only kept for isolated tests.
SPORTTERY_DB_BACKEND=mysql
SPORTTERY_MYSQL_HOST=your-host
SPORTTERY_MYSQL_PORT=3309
SPORTTERY_MYSQL_USER=football
SPORTTERY_MYSQL_PASSWORD=your-password
SPORTTERY_MYSQL_DATABASE=football
SPORTTERY_MYSQL_CHARSET=utf8mb4
SPORTTERY_MYSQL_CONNECT_TIMEOUT=10
SPORTTERY_MYSQL_READ_TIMEOUT=30
SPORTTERY_MYSQL_WRITE_TIMEOUT=30
